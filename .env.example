# NicheScope environment configuration
# Copy to .env and fill in your values

# === YouTube API ===
YOUTUBE_API_KEY=your_youtube_api_key_here
# OAuth2 credentials (for user's own channel analytics)
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# === Database ===
DATABASE_URL=postgresql+asyncpg://nichescope:nichescope@localhost:5432/nichescope

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === App ===
APP_SECRET_KEY=change-me-to-a-random-string
APP_BASE_URL=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO
