# === YouTube API ===
YOUTUBE_API_KEY=your_youtube_api_key_here

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Webhook mode (recommended on Railway — Telegram POSTs to your app, no long-poll):
#   Use your service public URL + /webhook (or set origin only; /webhook is appended automatically).
#   Example: https://nichescope-production-xxxx.up.railway.app/webhook
#   Optional: TELEGRAM_WEBHOOK_SECRET — set the same value in Railway; sent as
#   X-Telegram-Bot-Api-Secret-Token (see nichescope/main.py).
#   Leave TELEGRAM_WEBHOOK_URL empty to use long-polling instead.
# TELEGRAM_WEBHOOK_URL=https://your-service.up.railway.app
# TELEGRAM_WEBHOOK_SECRET=
#
# Optional secret Telegram includes in X-Telegram-Bot-Api-Secret-Token header.
#   Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# TELEGRAM_WEBHOOK_SECRET=

# === Uber GenAI (Bearer token, no "Bearer " prefix) ===
GENAI_TOKEN=

# Required: OpenAI-compatible model id your GenAI project can call (403 if wrong / not allowlisted).
# Replace with an id from your internal GenAI project settings — not necessarily gpt-4.
GENAI_MODEL=

# GENAI_CHAT_URL=https://genai-api.uberinternal.com/v1/chat/completions

# === Moat MVP: competitor watchlist + daily digest (UTC) ===
# DIGEST_ENABLED=true
# DIGEST_HOUR_UTC=9
# Optional: full URL; default is sqlite under ./data/ (dev) or set for Postgres in prod
# DATABASE_URL=sqlite+aiosqlite:////app/data/nichescope.db

# === TLS / Corporate network ===
# Path to CA bundle inside the container (set in Dockerfile; override here if needed).
# SSL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# === App ===
LOG_LEVEL=INFO
